<?xml version="1.0" encoding="utf-8"?>
<!--
  original root: LinearLayout vertical, paddingBottom=24dp, bg #18181B cornerRadii[32,32,32,32,0,0,0,0]
-->
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:orientation="vertical"
  android:paddingBottom="24dp"
  android:background="@drawable/bg_bottom_sheet">

  <!--
    original handle: width=32dp, height=4dp, gravity=CENTER_HORIZONTAL
    marginTop=22dp, marginBottom=22dp, bg #66FFFFFF cornerRadius=2dp
  -->
  <View
    android:layout_width="32dp"
    android:layout_height="4dp"
    android:layout_gravity="center_horizontal"
    android:layout_marginTop="22dp"
    android:layout_marginBottom="22dp"
    android:background="@drawable/bg_sheet_handle" />

  <!--
    original header: LinearLayout horizontal
    paddingStart=24dp, paddingEnd=24dp, paddingBottom=16dp, gravity=CENTER_VERTICAL
  -->
  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="16dp"
    android:gravity="center_vertical">

    <!--
      original card: radius=8dp, bgColor=#2A2A2A, strokeWidth=0
      image inside: 64x64dp, scaleType=CENTER_CROP, tint=#FFCCCCCC
    -->
    <com.google.android.material.card.MaterialCardView
      android:layout_width="64dp"
      android:layout_height="64dp"
      app:cardBackgroundColor="@color/surface_container_dark"
      app:cardCornerRadius="8dp"
      app:strokeWidth="0dp">

      <ImageView
        android:id="@+id/img_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_photo_m3"
        android:tint="@color/img_placeholder_tint"
        android:contentDescription="@null" />

    </com.google.android.material.card.MaterialCardView>

    <!--
      original url text: maxLines=2, ellipsize=MIDDLE, textColor=#CAC4D0
      TextAppearance.Material3.LabelLarge, weight=1, marginStart=16dp
    -->
    <TextView
      android:id="@+id/txt_url"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:layout_marginStart="16dp"
      android:maxLines="2"
      android:ellipsize="middle"
      android:textColor="@color/on_surface_variant"
      android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

  </LinearLayout>

  <!-- original divider: height=1dp, color=#33CAC4D0 -->
  <View
    android:layout_width="match_parent"
    android:layout_height="1dp"
    android:background="@color/divider" />

  <!--
    original menu items: textColor=#F2F2F2, gravity=CENTER_VERTICAL
    TextAppearance.Material3.BodyLarge
    paddingStart/End=24dp, paddingTop/Bottom=16dp
    drawablePadding=16dp, drawable tint=#F2F2F2
    background = ?android:attr/selectableItemBackground
    (identik dengan resolveAttribute(android.R.attr.selectableItemBackground) original)
  -->
  <TextView
    android:id="@+id/btn_open"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Buka di browser"
    android:drawableStart="@drawable/ic_open_m3"
    android:drawableTint="@color/on_surface"
    android:drawablePadding="16dp"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:gravity="center_vertical"
    android:textColor="@color/on_surface"
    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true" />

  <TextView
    android:id="@+id/btn_copy"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Salin alamat link"
    android:drawableStart="@drawable/ic_copy_m3"
    android:drawableTint="@color/on_surface"
    android:drawablePadding="16dp"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:gravity="center_vertical"
    android:textColor="@color/on_surface"
    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true" />

  <TextView
    android:id="@+id/btn_download"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Download gambar"
    android:drawableStart="@drawable/ic_download_m3"
    android:drawableTint="@color/on_surface"
    android:drawablePadding="16dp"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:gravity="center_vertical"
    android:textColor="@color/on_surface"
    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true" />

  <TextView
    android:id="@+id/btn_share"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Bagikan gambar"
    android:drawableStart="@drawable/ic_share_m3"
    android:drawableTint="@color/on_surface"
    android:drawablePadding="16dp"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:gravity="center_vertical"
    android:textColor="@color/on_surface"
    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true" />

</LinearLayout>
