<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background Track (Warna #6F39EE dengan transparansi rendah - 15%) -->
    <item android:id="@android:id/background">
        <shape>
            <solid android:color="#266F39EE"/>
        </shape>
    </item>

    <!-- Secondary Progress (Warna #6F39EE dengan transparansi sedang - 50%) -->
    <item android:id="@android:id/secondaryProgress">
        <clip>
            <shape>
                <solid android:color="#806F39EE"/>
            </shape>
        </clip>
    </item>

    <!-- Main Progress (Warna Solid #6F39EE) -->
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <solid android:color="#6F39EE"/>
            </shape>
        </clip>
    </item>
</layer-list>
